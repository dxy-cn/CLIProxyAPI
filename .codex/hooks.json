{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/bin/sh -lc 'root=$(git rev-parse --show-toplevel 2>/dev/null || pwd); python3 \"$root/.codex/hooks/stop_review.py\"'",
            "timeout": 30,
            "statusMessage": "Reviewing backend changes"
          }
        ]
      }
    ]
  }
}
